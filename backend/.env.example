# ─── Driver ──────────────────────────────────────────────────────────────
# Which database the backend talks to.
#   postgres → web build (multi-user, one shared database)
#   sqlite   → desktop build (embedded, one .sqlite file per board)
DB_DRIVER=postgres

# ─── Postgres (DB_DRIVER=postgres) ───────────────────────────────────────
DATABASE_URL=postgresql://kanban:kanban@localhost:5433/kanban

# ─── SQLite (DB_DRIVER=sqlite) ───────────────────────────────────────────
# Path to the active board's .sqlite file. The Electron shell overrides
# this per board; for local dev with sqlite you can leave the default.
DATABASE_PATH=./data/kanban.sqlite

# ─── Auth ────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_hex_string

# Optional: first-time admin seeded on an empty users table. Leave unset
# in production — fallback is admin@kanban.local / admin123 (CHANGE IT).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ─── Encryption ──────────────────────────────────────────────────────────
# 64-hex chars (32 bytes). Used for sensitive credential blobs.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── AI (optional) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Mailer (optional — unset = dry-run, sends are only logged) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="MKS Kanban <noreply@example.com>"

# ─── App ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3100

# ─── Frontend dist (only when backend serves the React app) ──────────────
# Absolute path to the built frontend. Leave unset to use the in-repo
# `../frontend/dist` automatically. The Docker image sets this to /app/public.
# FRONTEND_DIST=

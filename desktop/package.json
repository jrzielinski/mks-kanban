{
  "name": "mks-kanban-desktop",
  "version": "0.1.0",
  "description": "MKS Kanban — Electron desktop app",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "npm run build --prefix ../frontend",
    "build:backend": "npm run build --prefix ../backend",
    "build": "npm run build:renderer && npm run build:backend && npm run build:main && npm run rebuild:backend-native",
    "rebuild:backend-native": "electron-rebuild --module-dir ../backend",
    "pack": "bash scripts/pack-kanban.sh",
    "pack:dir": "bash scripts/pack-kanban.sh && electron-builder --dir --config electron-builder.json",
    "dev": "npm run build && electron --no-sandbox .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^20.12.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "typescript": "^5.4.0"
  }
}
